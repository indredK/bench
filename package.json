{
  "name": "bench",
  "private": true,
  "version": "1.16.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "setup": "node scripts/bootstrap/setup.mjs",
    "setup:unix": "node scripts/bootstrap/setup.mjs",
    "check:precommit": "node scripts/quality/pre-commit-check.mjs",
    "commitlint": "node scripts/quality/commit-msg-check.mjs",
    "hooks:install": "node scripts/bootstrap/install-hooks.mjs",
    "prepare": "node scripts/bootstrap/install-hooks.mjs",
    "postinstall": "node scripts/bootstrap/install-hooks.mjs",
    "dev:fe": "vite",
    "build:fe": "tsc && vite build",
    "preview:fe": "vite preview",
    "lint:fe": "node scripts/quality/check-i18n-guards.mjs && tsc --noEmit",
    "test:fe": "vitest run",
    "test:fe:watch": "vitest",
    "test:critical": "vitest run src/features/account-manager src/features/token-calculator src/features/app-manager src/components/common/__tests__/SettingsDialog.test.tsx",
    "test:be": "cd src-tauri && cargo test",
    "check:be": "cd src-tauri && cargo check",
    "clippy:be": "cd src-tauri && cargo clippy -- -D warnings",
    "clean:be": "cd src-tauri && cargo clean",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:debug": "tauri build --debug",
    "test": "npm run test:fe && npm run test:be",
    "verify": "npm run test:fe && npm run test:be && npm run build:fe && npm run build:debug",
    "ci": "npm ci && npm run verify"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^26.2.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "shadcn": "^4.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
